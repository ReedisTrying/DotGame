    - type: 7
      intValue: 2
  - buttonText: "【刮取冷色】"
    hoverText: "获得 2 个蓝点。"
    effects:
    - type: 8
      intValue: 2
  - buttonText: "【离开】太脏了"
    hoverText: "什么都不做。"
    effects:
    - type: 6
      intValue: 0
