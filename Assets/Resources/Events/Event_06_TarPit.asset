    hoverText: "选择一颗骰子，将目标面设为 3 点。"
    effects:
    - type: 19
      intValue: 3
  - buttonText: "【提炼】收集黑油"
    hoverText: "法力骰获得 2 个墨点。"
    effects:
    - type: 16
      intValue: 2
  - buttonText: "【离开】远离这里"
    hoverText: "什么都不做。"
    effects:
    - type: 6
      intValue: 0
