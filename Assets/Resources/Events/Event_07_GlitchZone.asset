    - type: 20
      intValue: 0
  - buttonText: "【捕捉残影】"
    hoverText: "支付 $10 金粉。获得 1 个重影点。"
    effects:
    - type: 3
      intValue: 10
    - type: 12
      intValue: 1
  - buttonText: "【离开】为了数据安全"
    hoverText: "什么都不做。"
    effects:
    - type: 6
      intValue: 0
