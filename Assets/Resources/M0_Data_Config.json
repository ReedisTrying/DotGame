      "condition": "每1对红绿骰子销毁怪物1点攻击力 (M0简化实现)"
    },
    "blue_green_bloom": {
      "name": "滋养 (Bloom)",
      "effect": "extra_dice_next_turn",
      "val": 1,
      "condition": "每1对蓝绿骰子使下回合手牌上限+1 (M0简化实现)"
    }
  },

